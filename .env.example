# =====================================================================
# N² Squad Studio — variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha os SEU_VALOR_AQUI.
# NUNCA versione o .env.local (ele tem segredos).
# =====================================================================

# ---- Anthropic (Claude) ---- OBRIGATÓRIO
ANTHROPIC_API_KEY=SEU_VALOR_AQUI
# (opcionais — sobrescrevem os modelos padrão do código)
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_WRITE_MODEL=claude-opus-4-8
ANTHROPIC_CARDS_MODEL=claude-sonnet-4-6
ANTHROPIC_LEARN_MODEL=claude-sonnet-4-6

# ---- Voyage AI (embeddings do RAG) ---- opcional (só pra base de livros/ciência)
VOYAGE_API_KEY=SEU_VALOR_AQUI
VOYAGE_MODEL=voyage-3.5-lite

# ---- Exa (busca semântica das pontes de correlação) ---- opcional
EXA_API_KEY=SEU_VALOR_AQUI

# ---- Supabase (a app lê estas) ---- OBRIGATÓRIO
SUPABASE_URL=SEU_VALOR_AQUI
NEXT_PUBLIC_SUPABASE_URL=SEU_VALOR_AQUI
SUPABASE_SERVICE_ROLE_KEY=SEU_VALOR_AQUI
SUPABASE_SECRET_KEY=SEU_VALOR_AQUI

# ---- Postgres direto (só os scripts setup-db/ingest usam) ----
POSTGRES_URL=SEU_VALOR_AQUI
POSTGRES_URL_NON_POOLING=SEU_VALOR_AQUI
POSTGRES_PRISMA_URL=SEU_VALOR_AQUI
POSTGRES_HOST=SEU_VALOR_AQUI
POSTGRES_USER=SEU_VALOR_AQUI
POSTGRES_PASSWORD=SEU_VALOR_AQUI
POSTGRES_DATABASE=SEU_VALOR_AQUI

# ---- Outras chaves Supabase (geradas pelo Supabase/Vercel; não usadas direto pelo app) ----
NEXT_PUBLIC_SUPABASE_ANON_KEY=SEU_VALOR_AQUI
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=SEU_VALOR_AQUI
SUPABASE_ANON_KEY=SEU_VALOR_AQUI
SUPABASE_PUBLISHABLE_KEY=SEU_VALOR_AQUI
SUPABASE_JWT_SECRET=SEU_VALOR_AQUI
VERCEL_OIDC_TOKEN=SEU_VALOR_AQUI
